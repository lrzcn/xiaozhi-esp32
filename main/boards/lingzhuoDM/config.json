{
    "target": "esp32c3",
    "builds": [
        {
            "name": "lingzhuoDM",
            "sdkconfig_append": [
                "CONFIG_PM_ENABLE=y",
                "CONFIG_FREERTOS_USE_TICKLESS_IDLE=y",
                "CONFIG_USE_ESP_WAKE_WORD=y",
                "CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y",
                "CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y",
                "CONFIG_ESPTOOLPY_FLASHSIZE=\"16MB\""
            ]
        }
    ]
}
